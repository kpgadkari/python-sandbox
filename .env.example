# Copy to .env and adjust before deploy: cp .env.example .env

# Web UI (change passwords in production)
SANDBOX_USERNAME=parent
SANDBOX_PASSWORD=change-me
SANDBOX_CHILD_USERNAME=son
SANDBOX_CHILD_PASSWORD=python
SANDBOX_HTTP_PORT=8090

# Optional display names for seeded accounts
# SANDBOX_DISPLAY_NAME=Parent
# SANDBOX_CHILD_DISPLAY_NAME=Young Coder

# App data: project files (use an OMV shared-folder path on the NAS)
SANDBOX_DATA_PATH=./data

# Optional: shown in deploy.sh success message (defaults to first LAN IP)
# SANDBOX_PUBLIC_HOST=192.168.1.50

# MariaDB (bundled container)
SANDBOX_MARIADB_PASSWORD=sandbox
SANDBOX_MARIADB_ROOT_PASSWORD=sandbox-root
SANDBOX_MARIADB_PORT=3306

# Backend-only / integration tests (not used by compose stack startup)
DATABASE_URL=mysql://sandbox:sandbox@127.0.0.1:3306/python_sandbox
SANDBOX_TEST_DATABASE_URL=mysql://sandbox:sandbox@127.0.0.1:3306/python_sandbox
