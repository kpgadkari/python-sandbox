{
  "name": "python-sandbox-frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node scripts/copy-pyodide.mjs && vite --host 0.0.0.0",
    "build": "node scripts/copy-pyodide.mjs && tsc && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "test": "vitest run",
    "coverage": "vitest run --coverage --coverage.include='src/**/*.{ts,tsx}'"
  },
  "dependencies": {
    "@codemirror/lang-python": "^6.1.6",
    "@codemirror/theme-one-dark": "^6.1.2",
    "@uiw/react-codemirror": "^4.23.10",
    "lucide-react": "^0.468.0",
    "pyodide": "^0.29.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.4.8",
    "@testing-library/react": "^15.0.7",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "@vitest/coverage-v8": "^2.1.9",
    "typescript": "^5.5.4",
    "vite": "^5.4.0",
    "vitest": "^2.0.5"
  }
}
